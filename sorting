# bubblu sort

l=[-7,7,11,5]
for i in range(len(l)-1,0,-1):
    for j in range(0,i):
        if l[j]>l[j+1]:
            l[j],l[j+1]=l[j+1],l[j]
    print(l)   

# selection sort

l=[-7,7,3,5,2,-10,1,-11]
for i in range(len(l)-1):
    m=i
    for j in range(i+1,len(l)):
        if l[m]>l[j]:
            m=j
            l[i],l[m]=l[m],l[i]
print(l)            
        
        
