#27. Strong Number Check
#Question: Check if a number is a strong number. Explanation: Sum of factorial of digits equals the number.
- Input: 145 - Output: Strong number
n=145
m=n
sum=0
while n>0:
    d=n%10
    c=1
    for i in range(1,d+1):
        c=c*i
    sum=sum+c
    n=n//10
if sum==m:
    print("strong number")
else:
    print("not a strongnumber")

